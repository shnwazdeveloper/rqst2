# Copy to .env and fill in values.
# Leave WEBHOOK_URL empty for local polling mode.

BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username_without_@

CHANNEL1=YourUpdateChannel
CHANNEL2=YourMoreBotsChannel

MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=auto_approve_bot

# Set on Render to enable webhook mode:
# WEBHOOK_URL=https://your-app.onrender.com
WEBHOOK_URL=

PORT=3000
